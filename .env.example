# Copy this file to .env and fill in your own key. Never commit the real .env.
# Free sign-up: https://www.api-football.com/ (or via RapidAPI) -- free tier is
# 100 requests/day, which is enough since we cache aggressively.
API_FOOTBALL_KEY=

# Sign up at https://oddspapi.io/ -- used for BetMGM sportsbook odds (BetMGM
# has no public API of its own; this aggregates it along with 350+ other books).
ODDSPAPI_KEY=
